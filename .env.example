# ─── Postgres ───
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=finsight_password
POSTGRES_DB=finsight_db

# ─── Kafka ───
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── Service Discovery / Config ───
EUREKA_URL=http://discovery-server:8761/eureka
CONFIG_SERVER_URL=http://config-server:8888

# ─── Observability ───
ZIPKIN_URL=http://zipkin:9411/api/v2/spans
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── Service URLs (workflow-service downstream) ───
DOCUMENT_SERVICE_URL=http://document-service:8082
AI_SERVICE_URL=http://ai-service:8083

# ─── Auth ───
JWT_SECRET=replace-with-256-bit-base64-secret
JWT_EXPIRATION_MS=3600000

# ─── AI ───
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-8b-8192

# Backward-compatible OpenAI vars
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=llama3-8b-8192

# ─── Frontend ───
VITE_API_BASE_URL=http://localhost:8080
